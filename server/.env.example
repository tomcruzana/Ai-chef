APP_ENV=local
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
GUEST_SESSION_TTL_HOURS=24

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_chef
DB_USERNAME=root
DB_PASSWORD=

# Recipe generation provider: mock, openai, or mistral.
# Keep the real key only in server/.env, never in React code and never committed to GitHub.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

MAIL_ENABLED=false
MAIL_TO=
MAIL_FROM=
MAIL_DRIVER=database
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
