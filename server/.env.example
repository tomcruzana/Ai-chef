APP_ENV=local
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000

# Recipe generation provider: mock, openai, or mistral.
# Keep the real key only in server/.env, never in React code and never committed to GitHub.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

MAIL_ENABLED=false
MAIL_TO=
MAIL_FROM=
MAIL_DRIVER=json
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
