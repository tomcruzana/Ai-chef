{"ast":null,"code":"import{createSlice,nanoid}from\"@reduxjs/toolkit\";const initialState={items:[]};const shoppingListSlice=createSlice({name:\"shoppingList\",initialState,reducers:{addShoppingItems:{reducer(state,action){action.payload.forEach(item=>{const name=typeof item===\"string\"?item:item.name;const exists=state.items.some(current=>current.name.toLowerCase()===name.toLowerCase());if(!exists){state.items.push({id:nanoid(),name,checked:false});}});},prepare(items){return{payload:Array.isArray(items)?items:[]};}},toggleShoppingItem(state,action){const item=state.items.find(current=>current.id===action.payload);if(item)item.checked=!item.checked;},removeShoppingItem(state,action){state.items=state.items.filter(item=>item.id!==action.payload);}}});export const{addShoppingItems,toggleShoppingItem,removeShoppingItem}=shoppingListSlice.actions;export default shoppingListSlice.reducer;","map":{"version":3,"names":["createSlice","nanoid","initialState","items","shoppingListSlice","name","reducers","addShoppingItems","reducer","state","action","payload","forEach","item","exists","some","current","toLowerCase","push","id","checked","prepare","Array","isArray","toggleShoppingItem","find","removeShoppingItem","filter","actions"],"sources":["C:/Users/Everblue Software/Projects/Github Portfolio Projects/Ai-chef/src/features/shoppingList/shoppingListSlice.js"],"sourcesContent":["import { createSlice, nanoid } from \"@reduxjs/toolkit\";\r\n\r\nconst initialState = {\r\n  items: [],\r\n};\r\n\r\nconst shoppingListSlice = createSlice({\r\n  name: \"shoppingList\",\r\n  initialState,\r\n  reducers: {\r\n    addShoppingItems: {\r\n      reducer(state, action) {\r\n        action.payload.forEach((item) => {\r\n          const name = typeof item === \"string\" ? item : item.name;\r\n          const exists = state.items.some((current) => current.name.toLowerCase() === name.toLowerCase());\r\n\r\n          if (!exists) {\r\n            state.items.push({ id: nanoid(), name, checked: false });\r\n          }\r\n        });\r\n      },\r\n      prepare(items) {\r\n        return { payload: Array.isArray(items) ? items : [] };\r\n      },\r\n    },\r\n    toggleShoppingItem(state, action) {\r\n      const item = state.items.find((current) => current.id === action.payload);\r\n      if (item) item.checked = !item.checked;\r\n    },\r\n    removeShoppingItem(state, action) {\r\n      state.items = state.items.filter((item) => item.id !== action.payload);\r\n    },\r\n  },\r\n});\r\n\r\nexport const { addShoppingItems, toggleShoppingItem, removeShoppingItem } = shoppingListSlice.actions;\r\nexport default shoppingListSlice.reducer;\r\n"],"mappings":"AAAA,OAASA,WAAW,CAAEC,MAAM,KAAQ,kBAAkB,CAEtD,KAAM,CAAAC,YAAY,CAAG,CACnBC,KAAK,CAAE,EACT,CAAC,CAED,KAAM,CAAAC,iBAAiB,CAAGJ,WAAW,CAAC,CACpCK,IAAI,CAAE,cAAc,CACpBH,YAAY,CACZI,QAAQ,CAAE,CACRC,gBAAgB,CAAE,CAChBC,OAAOA,CAACC,KAAK,CAAEC,MAAM,CAAE,CACrBA,MAAM,CAACC,OAAO,CAACC,OAAO,CAAEC,IAAI,EAAK,CAC/B,KAAM,CAAAR,IAAI,CAAG,MAAO,CAAAQ,IAAI,GAAK,QAAQ,CAAGA,IAAI,CAAGA,IAAI,CAACR,IAAI,CACxD,KAAM,CAAAS,MAAM,CAAGL,KAAK,CAACN,KAAK,CAACY,IAAI,CAAEC,OAAO,EAAKA,OAAO,CAACX,IAAI,CAACY,WAAW,CAAC,CAAC,GAAKZ,IAAI,CAACY,WAAW,CAAC,CAAC,CAAC,CAE/F,GAAI,CAACH,MAAM,CAAE,CACXL,KAAK,CAACN,KAAK,CAACe,IAAI,CAAC,CAAEC,EAAE,CAAElB,MAAM,CAAC,CAAC,CAAEI,IAAI,CAAEe,OAAO,CAAE,KAAM,CAAC,CAAC,CAC1D,CACF,CAAC,CAAC,CACJ,CAAC,CACDC,OAAOA,CAAClB,KAAK,CAAE,CACb,MAAO,CAAEQ,OAAO,CAAEW,KAAK,CAACC,OAAO,CAACpB,KAAK,CAAC,CAAGA,KAAK,CAAG,EAAG,CAAC,CACvD,CACF,CAAC,CACDqB,kBAAkBA,CAACf,KAAK,CAAEC,MAAM,CAAE,CAChC,KAAM,CAAAG,IAAI,CAAGJ,KAAK,CAACN,KAAK,CAACsB,IAAI,CAAET,OAAO,EAAKA,OAAO,CAACG,EAAE,GAAKT,MAAM,CAACC,OAAO,CAAC,CACzE,GAAIE,IAAI,CAAEA,IAAI,CAACO,OAAO,CAAG,CAACP,IAAI,CAACO,OAAO,CACxC,CAAC,CACDM,kBAAkBA,CAACjB,KAAK,CAAEC,MAAM,CAAE,CAChCD,KAAK,CAACN,KAAK,CAAGM,KAAK,CAACN,KAAK,CAACwB,MAAM,CAAEd,IAAI,EAAKA,IAAI,CAACM,EAAE,GAAKT,MAAM,CAACC,OAAO,CAAC,CACxE,CACF,CACF,CAAC,CAAC,CAEF,MAAO,MAAM,CAAEJ,gBAAgB,CAAEiB,kBAAkB,CAAEE,kBAAmB,CAAC,CAAGtB,iBAAiB,CAACwB,